# Port the HTTP server listens on.
PORT=8080

# Node environment. `development` relaxes the boot guards below.
NODE_ENV=development

# ── Inbound auth ─────────────────────────────────────────────────────────
# Shared bearer token: every /ops/*, /connections* request must send
#   Authorization: Bearer <GMAIL_TOOL_TOKEN>
# hadron-server holds the same value as GMAIL_TOOL_TOKEN.
# Required in production — the service refuses to start without it.
GMAIL_TOOL_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────
# The tool's OWN database (never core's). Holds encrypted refresh tokens,
# watch state + history cursors, dedupe + idempotency records.
# Required in production — the service refuses to start without it.
DATABASE_URL=postgresql://holger@localhost:5432/hadrontool_gmail

# ── Secrets ──────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of refresh tokens at rest.
# Distinct from core's HADRON_ENCRYPTION_KEY and from the ms-exchange tool's
# key by design. Required in production.
TOKEN_ENCRYPTION_KEY=

# ── Google OAuth client (the MAILBOX project — never the login project) ──
# The tool owns the client secret; hadron-server only builds the user-facing
# authorize URL (client id is public, mirrored there as GMAIL_CLIENT_ID).
# Without these, /connections and all mail operations return typed errors —
# the HTTP surface still boots.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Pub/Sub push ingress (public) ────────────────────────────────────────
# The Cloud Pub/Sub topic Gmail watch notifications publish to. Grant
# gmail-api-push@system.gserviceaccount.com the Publisher role on it.
PUBSUB_TOPIC=projects/<project>/topics/<topic>

# Shared verification token appended to the push subscription's endpoint URL
# (https://<public-host>/webhooks/gmail?token=<value>); verified constant-time
# on every push. Required in production.
PUBSUB_VERIFICATION_TOKEN=

# ── Event plane (tool → core) ────────────────────────────────────────────
# Where normalized email events are POSTed (hadron-server's internal ingress),
# and the bearer token that call carries. Required in production — an unset URL
# would log+drop every event as "success" and advance the history cursor,
# losing mail events unrecoverably. Unset is dev-only (degrades to log+drop).
CORE_EVENTS_URL=
CORE_EVENTS_TOKEN=

# Max request body size accepted by the JSON parser.
MAX_BODY_SIZE=2mb
