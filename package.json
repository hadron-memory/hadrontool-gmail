{
  "name": "@hadron/hadrontool-gmail",
  "version": "0.1.0",
  "description": "Hadron Gmail tool — owns the Google Gmail provider relationship: OAuth tokens, mail operations, and Pub/Sub watch notifications, behind a provider-neutral HTTP surface.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "generate": "prisma generate",
    "typecheck": "prisma generate && tsc --noEmit",
    "pretest": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:test-setup": "DATABASE_URL=postgresql://holger@localhost:5432/hadrontool_gmail_test prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
